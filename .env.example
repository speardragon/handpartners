# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AWS S3
AWS_REGION=
# AWS_S3_REGION (대체값): AWS_REGION 대신 사용 가능
AWS_S3_REGION=

AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=

AWS_S3_BUCKET=
# 선택: 커스텀 도메인 또는 CloudFront 등 공개 URL 베이스
AWS_S3_PUBLIC_URL_BASE=
# 선택: S3 호환 API endpoint (예: MinIO, LocalStack)
AWS_S3_ENDPOINT=
# 선택: pre-signed URL 만료(초), 기본값 300
AWS_S3_PRESIGNED_EXPIRES_IN=

# Email (Resend)
RESEND_API_KEY=
# 이메일 내 심사 링크 생성에 사용 (예: https://yourapp.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
